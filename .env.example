# Aether MEV Bot - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env && chmod 600 .env
#
# ═══════════════════════════════════════════════════════════════════════════
# IMPORTANT SECURITY NOTES
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. SEARCHER_KEY is the HOT-WALLET private key that Flashbots uses to
#    sign bundle submissions via X-Flashbots-Signature. This key MUST:
#    - Hold only ~0.5 ETH (enough for gas, minimal loss exposure)
#    - NEVER hold more than ~1 ETH
#    - Be a dedicated searcher wallet (not your main wallet)
#    - Be kept in .env with chmod 600
#
# 2. The .env file is git-ignored by default. Double-check it never
#    gets committed: git add .env should NOT stage it.
#
# 3. For production, consider using the remote signer (cmd/signer) so
#    the SEARCHER_KEY never lives in an env variable at all. The key is
#    encrypted at rest and decrypted only in the signer process.
#
# 4. Run in SHADOW MODE (AETHER_SHADOW=1) first for at least 24 hours
#    to validate bundles before going live (AETHER_SHADOW=0).
#
# 5. Builder API keys (TITAN_API_KEY, etc.) are optional. Most builders
#    accept bundles without auth in 2026. Only set if the builder requires
#    one for your tier.
# ═══════════════════════════════════════════════════════════════════════════

# ── Ethereum RPC (REQUIRED) ─────────────────────────────────────────────────
# Alchemy is recommended (eth_pendingTransactions support for the mempool).
# Replace YOUR_KEY with your actual Alchemy API key.
ALCHEMY_API_KEY=your_alchemy_api_key_here
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# ── Rust Core ───────────────────────────────────────────────────────────────
RUST_LOG=info
AETHER_CONFIG_DIR=./config
# LOG_FORMAT=json switches the Rust tracing-subscriber to structured JSON for
# Promtail/Loki shipping. Leave unset for human-readable local output.
# LOG_FORMAT=json

# ── Go Executor ─────────────────────────────────────────────────────────────
GOMAXPROCS=2
GOGC=200
GRPC_ADDRESS=localhost:50051
METRICS_PORT=9090
DASHBOARD_PORT=8080

# ── SECRET: Searcher Hot-Wallet Private Key ─────────────────────────────────
# REQUIRED for Flashbots bundle submission. OPTIONAL in shadow mode (bundles
# are unsigned and never submitted). MUST be kept secret (chmod 600).
#
# Generate a dedicated key (never reuse a main wallet):
#   cast wallet new  # foundry
#   OR: openssl ecparam -name secp256k1 -genkey -noout -out searcher.pem
#
# Fund with ~0.5 ETH on mainnet. DO NOT hold more than ~1 ETH.
SEARCHER_KEY=your_searcher_wallet_private_key_here

# ── Block Builder Config ────────────────────────────────────────────────────
# These env vars are referenced by config/builders.yaml via ${VAR} expansion.
#
# Flashbots and BuilderNet use X-Flashbots-Signature auth (SEARCHER_KEY).
# Titan, Quasar, and Rsync accept bundles without auth (optional signature for reputation).
#
# FLASHBOTS_AUTH_KEY is an ALTERNATIVE to SEARCHER_KEY. Only set this if you
# obtained a Flashbots API key directly. Most users should leave it unset and
# rely on SEARCHER_KEY for Flashbots auth.
# FLASHBOTS_AUTH_KEY=

# ── Observability ───────────────────────────────────────────────────────────
# Slack webhook for alertmanager alerts. Create an incoming webhook at
# https://api.slack.com/messaging/webhooks and paste the full URL here.
# If empty, alertmanager refuses to start (safety: no silent alert loss).
SLACK_WEBHOOK_URL=

# OpenTelemetry trace export. Set to host:port of an OTLP/gRPC collector
# (Tempo in the compose stack) to stream spans. Leave unset for local dev.
# OTEL_EXPORTER_OTLP_ENDPOINT=tempo:4317
# OTEL_SERVICE_NAME=aether-executor

# ── Trade Ledger (Postgres, opt-in) ─────────────────────────────────────────
# When set, both binaries write arbs/bundles/inclusions to Postgres.
# Bring Postgres up with the `ledger` compose profile, then apply the schema:
#   docker compose --profile ledger up -d postgres
#   ./scripts/db_migrate.sh
# DATABASE_URL=postgres://aether:aether@localhost:5432/aether
# POSTGRES_USER=aether
# POSTGRES_PASSWORD=aether
# POSTGRES_DB=aether

# ── Mempool Tracking (opt-in) ───────────────────────────────────────────────
# When set to a truthy value, aether-rust subscribes to Alchemy
# pendingTransactions and aether-monitor connects to Flashbots MEV-Share SSE.
# Requires an Alchemy endpoint (ETH_RPC_URL). See docs for non-Alchemy options.
# MEMPOOL_TRACKING=1
# MEMPOOL_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
# MEV_SHARE_URL=https://mev-share.flashbots.net
