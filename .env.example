# Aether MEV Bot — Environment Configuration for Ethereum Mainnet
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env && chmod 600 .env
#
# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY NOTES (READ BEFORE DEPLOYING)
# ═══════════════════════════════════════════════════════════════════════════════
# 1. SEARCHER_KEY — HOT wallet. Hold ≤ 0.5 ETH. NEVER reuse main wallets.
# 2. chmod 600 .env. NEVER commit .env to git.
# 3. Run SHADOW MODE (AETHER_SHADOW=1) for ≥24h before going live.
# 4. For production key security, use cmd/signer (AES-256-GCM remote signer).
# ═══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED: Ethereum RPC ───────────────────────────────────────────────────
# Alchemy recommended (supports eth_pendingTransactions for mempool).
# Get a free key at https://www.alchemy.com
ALCHEMY_API_KEY=your_alchemy_api_key_here
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# ── REQUIRED: Mempool Tracking ───────────────────────────────────────────────
# Enables Alchemy pendingTransactions subscription + backrun pipeline
MEMPOOL_TRACKING=1
MEMPOOL_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
# Enables revm post-state replay for V3/Balancer tick-crossing victims
MEMPOOL_POST_STATE_REPLAY=1

# ── REQUIRED: Chain ID (Ethereum Mainnet = 1) ───────────────────────────────
AETHER_CHAIN_ID=1

# ── REQUIRED: Executor Contract ──────────────────────────────────────────────
# Deploy AetherExecutor.sol first with: forge script script/Deploy.s.sol
# Then set the deployed address here.
AETHER_EXECUTOR_ADDRESS=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45

# ── RUN MODE ─────────────────────────────────────────────────────────────────
# SHADOW MODE (safety): 1 = simulate + dump forensics, NO real submissions.
# Set to 0 ONLY after ≥24h shadow validation with real bundles.
AETHER_SHADOW=1

# Backrun mode: off | shadow_only | shadow_and_live | live_only
# - shadow_only: simulate only (safe, recommended first 24h)
# - shadow_and_live: simulate + submit real bundles (final)
# - live_only: submit real bundles without shadow sim output
AETHER_BACKRUN_MODE=shadow_only

# ── REQUIRED: Searcher Hot-Wallet (for Flashbots auth) ─────────────────────
# REQUIRED for live submissions. Optional in shadow mode (unsigned bundles).
# Generate: cast wallet new
# Fund with ~0.5 ETH mainnet. NEVER hold more than ~1 ETH.
SEARCHER_KEY=your_searcher_wallet_private_key_here

# ── SECURITY: Admin Token (REQUIRED in production) ──────────────────────────
# Used by telebot and admin HTTP endpoints. Generate with: openssl rand -hex 32
AETHER_ADMIN_TOKEN=your_admin_token_here

# ── OPTIONAL: Discovery / Pool Cache (already configured in discovery.toml) ──
# Hot cache automatically maintains top 500 scoring pools, refreshed every 5s.
# Discovery listens to 8 DEX factory events for new pools.
# No env vars needed — all config is in config/discovery.toml.

# ── RUST CORE LOGGING ────────────────────────────────────────────────────────
RUST_LOG=info
# Set to "json" for structured logs (Promtail/Loki shipping)
# LOG_FORMAT=json

# ── OPTIONAL: gRPC / Ports ───────────────────────────────────────────────────
# AETHER_CONFIG_DIR=./config
# GRPC_ADDRESS=127.0.0.1:50051
# RUST_METRICS_PORT=9092

# ── OPTIONAL: Executor Tuning ────────────────────────────────────────────────
# GOMAXPROCS=2
# GOGC=200
# METRICS_PORT=9090
# DASHBOARD_PORT=8080

# ── OPTIONAL: Simulator Caller Setup ─────────────────────────────────────────
# In-sim EOA that calls executeArb(). Must be a code-free EOA.
# 0x...dEaD is a well-known burn address (no code, safe).
# AETHER_SEARCHER_CALLER=0x000000000000000000000000000000000000dEaD
# AETHER_PROFIT_TOKEN=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2

# ── OPTIONAL: Mempool / RPC Tuning (production defaults) ────────────────────
# AETHER_MEMPOOL_MIN_PROFIT_WEI=200000000000000
# AETHER_MEMPOOL_MAX_TIP_BPS=9900
# AETHER_MEMPOOL_SIM_CONCURRENCY=4
# AETHER_MEMPOOL_SIM_TIMEOUT_MS=30000
# AETHER_MEMPOOL_SIM_RETRIES=1
# AETHER_RPC_CUPS=300
# AETHER_RPC_MAX_RETRIES=10
# AETHER_RPC_BACKOFF_MS=200
# AETHER_RPC_REQUEST_TIMEOUT_MS=10000
# AETHER_BOOT_FETCH_CONCURRENCY=3
# AETHER_PREWARM_CONCURRENCY=4

# ── OPTIONAL: Trade Ledger (Postgres) ────────────────────────────────────────
# Enables writing arb/bundle/inclusion records to Postgres.
# Docker compose: docker compose --profile ledger up -d postgres
# Schema: ./scripts/db_migrate.sh
# DATABASE_URL=postgres://aether:aether@localhost:5432/aether
# POSTGRES_USER=aether
# POSTGRES_PASSWORD=aether
# POSTGRES_DB=aether

# ── OPTIONAL: Observability ──────────────────────────────────────────────────
# Slack webhook for alertmanager alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
# OpenTelemetry trace export to Tempo (included in Docker stack)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
# OTEL_SERVICE_NAME=aether-executor

# ── OPTIONAL: Telegram Bot ──────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_ALERT_BOT_TOKEN=your_alert_bot_token
# TELEGRAM_ALERT_CHAT_ID=your_chat_id

# ── OPTIONAL: Redis (for production.toml) ────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ── OPTIONAL: Alert Integrations ─────────────────────────────────────────────
# PD_ROUTING_KEY=your_pagerduty_key
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx
# ALERT_WEBHOOK_URL=https://hooks.example.com/alerts

# ── OPTIONAL: Builder API Keys ───────────────────────────────────────────────
# Only set if a builder requires explicit API key auth.
# FLASHBOTS_AUTH_KEY=
# TITAN_API_KEY=
