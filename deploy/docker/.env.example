# Aether — Docker Compose deployment environment
# Copy to .env next to the compose files and fill in.
#
#   cp deploy/docker/.env.example deploy/docker/.env && chmod 600 deploy/docker/.env
#
# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════════════════════
# - SEARCHER_KEY: HOT wallet. Hold <= 0.5 ETH. Never reuse main wallets.
# - chmod 600 .env on VPS. Use restricted user (not root) for docker.
# - Run shadow mode (AETHER_SHADOW=1) for >= 24h before going live.
# - AETHER_ADMIN_TOKEN: generate with `openssl rand -hex 32`
# ═══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED: Ethereum Connectivity ──────────────────────────────────────────
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
MEMPOOL_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── RUN MODE ─────────────────────────────────────────────────────────────────
# 1 = shadow: simulate + dump forensics, NO real submission (safe, default).
# 0 = LIVE: real bundles, real funds. Flip after >=24h shadow validation.
AETHER_SHADOW=1

# Backrun mode progression:
#   shadow_only      — simulate only (safe, recommended first 24h)
#   shadow_and_live  — simulate + submit real bundles (gradual go-live)
#   live_only        — submit real bundles without shadow output
AETHER_BACKRUN_MODE=shadow_only

MEMPOOL_TRACKING=1
MEMPOOL_POST_STATE_REPLAY=1
AETHER_CHAIN_ID=1

# ── Backrun Simulator ────────────────────────────────────────────────────────
# Replace with your deployed AetherExecutor address when going live.
# The default is a placeholder (UniV3 SwapRouter02) for shadow mode only.
AETHER_EXECUTOR_ADDRESS=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45
AETHER_SEARCHER_CALLER=0x000000000000000000000000000000000000dEaD
AETHER_PROFIT_TOKEN=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2

# ── SECRET: Searcher Hot-Wallet Private Key ──────────────────────────────────
# REQUIRED to go live (Flashbots X-Flashbots-Signature). Optional in shadow.
# NEVER commit. chmod 600 .env. Hold ~0.5 ETH max.
# Generate: cast wallet new
SEARCHER_KEY=

# ── Security: Admin Token ────────────────────────────────────────────────────
# Used by telebot and admin HTTP endpoints. REQUIRED in production.
# Generate: openssl rand -hex 32
AETHER_ADMIN_TOKEN=

# ── Monitoring / Alerting (required if using alertmanager) ──────────────────
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# ── Trade Ledger (Postgres, `ledger` profile) ────────────────────────────────
POSTGRES_USER=aether
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aether

# ── Grafana Admin Password ──────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change-me

# ── Mempool / RPC Tuning (production defaults — uncomment to override) ──────
# AETHER_MEMPOOL_MIN_PROFIT_WEI=200000000000000
# AETHER_MEMPOOL_MAX_TIP_BPS=9900
# AETHER_MEMPOOL_SIM_CONCURRENCY=4
# AETHER_RPC_CUPS=300
# AETHER_RPC_MAX_RETRIES=10
# AETHER_RPC_BACKOFF_MS=200
# AETHER_RPC_REQUEST_TIMEOUT_MS=10000
# AETHER_MEMPOOL_SIM_RETRIES=1
# AETHER_MEMPOOL_SIM_TIMEOUT_MS=30000
# AETHER_BOOT_FETCH_CONCURRENCY=3
# AETHER_PREWARM_CONCURRENCY=4
