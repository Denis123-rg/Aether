# Aether deployment environment — copy to `.env` next to the compose files
# and fill in. `.env` is git-ignored and must be chmod 600 (holds the key).
#
#   cp deploy/docker/.env.example deploy/docker/.env && chmod 600 deploy/docker/.env
#
# Compose auto-loads `.env` from the directory you run `docker compose` in.

# ── REQUIRED: Ethereum connectivity ──────────────────────────────────────
# HTTPS RPC used for revm fork state + nonce/gas reads.
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# Pending-tx WebSocket for the mempool feed (Alchemy pendingTransactions).
MEMPOOL_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── RUN MODE (safety) ────────────────────────────────────────────────────
# 1 = shadow: simulate + dump forensics, NO real submission (recommended).
# 0 = LIVE: real bundles, real funds. Only flip after validation.
AETHER_SHADOW=1
# Enable the mempool-backrun tracking path (the recently hardened code path).
MEMPOOL_TRACKING=1
# revm post-state replay for V3/Balancer tick-crossing victims.
MEMPOOL_POST_STATE_REPLAY=1
AETHER_CHAIN_ID=1

# ── Backrun simulator: executor address + bytecode injection ─────────────
# The revm sim INJECTS the AetherExecutor runtime bytecode into its CacheDB
# (with the AAVE pool immutable spliced in), so the contract does NOT need to
# be deployed on the forked chain. Two requirements:
#   1. AETHER_EXECUTOR_ADDRESS must hold *some* code on the forked chain — the
#      Go executor runs eth_getCode at startup and aborts on an empty account.
#      The compose default (UniV3 SwapRouter02) satisfies this in shadow; set
#      your real deployment to go live.
#   2. The forge artifact must exist locally (run `forge build` in contracts/);
#      it's mounted into the container and the path defaults to it. Override
#      only to relocate.
AETHER_EXECUTOR_ADDRESS=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45
# AETHER_EXECUTOR_BYTECODE_PATH=/app/contracts/out/AetherExecutor.sol/AetherExecutor.json
# Searcher EOA that calls executeArb (the `caller` in sim) + profit token.
AETHER_SEARCHER_CALLER=0x0000000000000000000000000000000000000000
AETHER_PROFIT_TOKEN=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2

# ── SECRET: searcher hot-wallet private key (Go executor) ─────────────────
# OPTIONAL in shadow mode (unsigned; submission is blocked anyway). REQUIRED
# to go live. NEVER commit. Hold ~0.5 ETH only. Keep .env chmod 600.
SEARCHER_KEY=

# ── Fork pinning ─────────────────────────────────────────────────────────
# Leave UNSET in production — the backrun fork now pins to the detected block.
# Set to 1 only against an Anvil fork whose mined blocks don't resolve state.
# AETHER_BACKRUN_FORK_LATEST=1

# ── Optional: monitoring / alerting ──────────────────────────────────────
# Required only if you run the `alertmanager` service (it refuses to start
# without this). Remove the service or set this.
SLACK_WEBHOOK_URL=

# ── Optional: trade + mempool ledger (Postgres, `ledger` profile) ─────────
POSTGRES_USER=aether
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aether
# DATABASE_URL=postgres://aether:change-me@postgres:5432/aether
# MEMPOOL_LEDGER_DSN=postgres://aether:change-me@postgres:5432/aether

# ── Optional: mempool tuning (defaults are sane) ──────────────────────────
# AETHER_MEMPOOL_MIN_PROFIT_WEI=
# AETHER_MEMPOOL_GAS_PRICE_GWEI=
# AETHER_MEMPOOL_SIM_CONCURRENCY=
# AETHER_POOL_STATES_REFRESH_SECS=
