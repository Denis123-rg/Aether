{
  "title": "Aether SLI Overview",
  "uid": "aether-sli",
  "panels": [
    {
      "title": "Bundle submission rate",
      "type": "timeseries",
      "targets": [
        {"expr": "sum(rate(bundle_submission_total[5m])) by (status)", "legendFormat": "{{status}}"}
      ]
    },
    {
      "title": "Bundle inclusion latency p99",
      "type": "timeseries",
      "targets": [
        {"expr": "histogram_quantile(0.99, sum(rate(bundle_inclusion_latency_seconds_bucket[5m])) by (le))"}
      ]
    },
    {
      "title": "Arb profit (ETH)",
      "type": "timeseries",
      "targets": [
        {"expr": "increase(arb_profit_total{currency=\"eth\"}[1h])"}
      ]
    },
    {
      "title": "Redis connected",
      "type": "stat",
      "targets": [
        {"expr": "redis_connected"}
      ]
    }
  ]
}
